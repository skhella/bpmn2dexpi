{
  "name": "bpmn2dexpi",
  "private": true,
  "version": "0.1.0",
  "description": "A web-based tool for creating DEXPI-compliant block flow and process flow diagrams using BPMN notation",
  "author": "Shady Khella",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skhella/bpmn2dexpi.git"
  },
  "keywords": [
    "dexpi",
    "bpmn",
    "process-engineering",
    "block-flow-diagram",
    "process-flow-diagram",
    "chemical-engineering",
    "xml"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "transform": "node --import tsx cli.js"
  },
  "dependencies": {
    "bpmn-js": "^18.10.1",
    "bpmn-js-properties-panel": "^5.48.0",
    "diagram-js": "^15.6.0",
    "jsdom": "^27.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
